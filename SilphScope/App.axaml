<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SilphScope.App"
             xmlns:local="using:SilphScope"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="/Styles/CardStyles.axaml"/>
		<StyleInclude Source="/Styles/StartStopToggleButtonStyle.axaml"/>
        <StyleInclude Source="/Styles/ConnectionBarStyles.axaml"/>
    </Application.Styles>

    <Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
                <MergeResourceInclude Source="/Assets/Fonts/SilphFonts.axaml"/>
				<MergeResourceInclude Source="/Assets/Images/MaterialIcons/IconThemes.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
<ResourceDictionary xmlns="https://github.com/avaloniaui"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<!-- Add Resources Here -->
	<ResourceDictionary.ThemeDictionaries>
		<ResourceDictionary x:Key="Light">
			<Svg x:Key="TrainerIcon" Path="/Assets/Images/MaterialIcons/article_black.svg"/>
			<Svg x:Key="TeamIcon" Path="/Assets/Images/MaterialIcons/groups_black.svg"/>
			<Svg x:Key="BoxIcon" Path="/Assets/Images/MaterialIcons/box_black.svg"/>
			<Svg x:Key="SettingsIcon" Path="/Assets/Images/MaterialIcons/settings_black.svg"/>
		</ResourceDictionary>
		<ResourceDictionary x:Key="Dark">
			<Svg x:Key="TrainerIcon" Path="/Assets/Images/MaterialIcons/article_white.svg"/>
			<Svg x:Key="TeamIcon" Path="/Assets/Images/MaterialIcons/groups_white.svg"/>
			<Svg x:Key="BoxIcon" Path="/Assets/Images/MaterialIcons/box_white.svg"/>
			<Svg x:Key="SettingsIcon" Path="/Assets/Images/MaterialIcons/settings_white.svg"/>
		</ResourceDictionary>
	</ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>

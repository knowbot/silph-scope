<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:vm="clr-namespace:SilphScope.ViewModels"
			 xmlns:local="using:SilphScope"
			 x:Class="SilphScope.ucMove"
			 x:DataType="vm:MoveViewModel">
	<Border Background="White" HorizontalAlignment="Stretch">
		<DockPanel>
			<!-- Type brush -->
			<Rectangle DockPanel.Dock="Left" Width="3" VerticalAlignment="Stretch" Fill="{Binding MoveType.Brush1}"/>

			<!-- PP -->
			<StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
				<TextBlock Text="{Binding CurrentPP}"/>
				<TextBlock Text="/"/>
				<TextBlock Text="{Binding TotPP}"/>
			</StackPanel>

			<!-- Name -->
			<TextBlock Text="{Binding Name}"/>
		</DockPanel>
	</Border>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:SilphScope.ViewModels"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="SilphScope.Views.ucGame"
			 x:DataType="vm:GameViewModel">
	<DockPanel>
		<Image DockPanel.Dock="Left" Source="{Binding Icon}" VerticalAlignment="Center" Width="16" Height="16"></Image>

		<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4 0 0 0">
			<TextBlock Text="{Binding ProductId, StringFormat={}[{0}]}"/>
			<TextBlock Text=" "/>
			<TextBlock Text="{Binding Name}"/>
		</StackPanel>
	</DockPanel>
</UserControl>

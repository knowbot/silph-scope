<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:vm="using:SilphScope.ViewModels"
		xmlns:local="using:SilphScope"
		mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
		x:Class="SilphScope.Views.MainWindow"
		x:DataType="vm:MainWindowViewModel"
		Icon="/Assets/silph-logo.ico"
		Title="SilphScope">
	<Design.DataContext>
		<!-- This only sets the DataContext for the previewer in an IDE,
		to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
		<vm:MainWindowViewModel/>
	</Design.DataContext>

	<DockPanel>
        <Border DockPanel.Dock="Top" Height="40" BorderBrush="#333" BorderThickness="0,0,0,1" Background="#141316">
            <Grid>
				<!-->NO PROCESS ATTACHED</!-->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" IsVisible="{Binding !Service.ShouldStart}">
                    <TextBlock FontFamily="{StaticResource SpaceMono}" Margin="10,5" Foreground="#FF5454">DISCONNECTED</TextBlock>
                </StackPanel>
                <!-->ATTACHED AND SCANNING</!-->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" IsVisible="{Binding Service.ShouldStart}">
                    <Border Classes="Pulse"
                                Background="#54FF54"
                                CornerRadius="8"
                                Margin="10 0 0 0"
                                Width="8" Height="8"
                                HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock  FontFamily="{StaticResource SpaceMono}" Margin="10,5">
                        <Run Foreground="#54FF54" Text="CONNECTED"/>
                        <Run Text="|" Foreground="#D5D3D9"/>
                        <Run Text="{Binding Service.TargetProcess.Name}" Foreground="#D5D3D9"/>
                        <Run Text="{Binding Service.TargetProcess.Pid, StringFormat='[PID: {0}]'}" Foreground="#D5D3D9"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" IsVisible="{Binding Service.ShouldStart}">
					<TextBlock FontFamily="{StaticResource SpaceMono}" Text="{Binding Service.TargetGame.Name}" Margin="10,5" Foreground="#D5D3D9" />
                </StackPanel>
            </Grid>
        </Border>

		<!-- Main content & log -->
		<Panel>
			<!-- Content -->
			<TabControl HorizontalAlignment="Stretch" TabStripPlacement="Left">
				<TabItem>
					<TabItem.Header>
						<Border Width="32" Height="32" Child="{DynamicResource SettingsIcon}"/>
					</TabItem.Header>
					<local:ucSettingsTab DataContext="{Binding SettingsTab}"/>
				</TabItem>
				<TabItem>
					<TabItem.Header>
						<Border Width="32" Height="32" Child="{DynamicResource TrainerIcon}"/>
					</TabItem.Header>
				</TabItem>
				<TabItem>
					<TabItem.Header>
						<Border Width="32" Height="32" Child="{DynamicResource PartyIcon}"/>
					</TabItem.Header>
					<local:ucPartyTab DataContext="{Binding PartyTab}"/>
				</TabItem>
				<TabItem>
					<TabItem.Header>
						<Border Width="32" Height="32" Child="{DynamicResource BoxIcon}"/>
					</TabItem.Header>
					<local:ucBoxTab DataContext="{Binding BoxTab}"/>
				</TabItem>
			</TabControl>

			<!-- Log -->
			<local:ucLog DockPanel.Dock="Bottom" DataContext="{Binding Log}"/>
		</Panel>
	</DockPanel>

</Window>

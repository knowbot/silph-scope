<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:vm="clr-namespace:SilphScope.ViewModels"
			 xmlns:local="using:SilphScope"
			 x:Class="SilphScope.ucTypes"
			 x:DataType="vm:TypesViewModel">
	<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
		<Border CornerRadius="4" Padding="4" Background="{Binding Brush1}" VerticalAlignment="Center">
			<TextBlock Text="{Binding Type1}" FontWeight="Bold" Foreground="White"/>
		</Border>
		<StackPanel Orientation="Horizontal" VerticalAlignment="Center" IsVisible="{Binding Type2, Converter={x:Static ObjectConverters.IsNotNull}}">
			<TextBlock Text="/" VerticalAlignment="Center" Margin="4 0 4 0"/>
			<Border CornerRadius="4" Padding="4" Background="{Binding Brush2}" VerticalAlignment="Center">
				<TextBlock Text="{Binding Type2}" FontWeight="Bold" Foreground="White"/>
			</Border>
		</StackPanel>
	</StackPanel>
</UserControl>

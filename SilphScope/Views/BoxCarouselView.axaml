<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:SilphScope.ViewModels"
			 xmlns:local="using:SilphScope"
			 xmlns:views="using:SilphScope.Views"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="SilphScope.Views.BoxCarouselView"
			 x:DataType="vm:BoxesViewModel">
	<Design.DataContext>
		<vm:BoxesViewModel/>
	</Design.DataContext>

	<!-- A carrousel of boxes with controls to move back and forward -->
	<DockPanel>
		<DockPanel DockPanel.Dock="Top">
			<Button DockPanel.Dock="Left" Content="Prev"/>
			<Button DockPanel.Dock="Right" Content="Next"/>
			<TextBlock Text="{Binding Selected.Name}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
		</DockPanel>

		<Carousel ItemsSource="{Binding Boxes}" SelectedItem="{Binding Selected}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
			<Carousel.ItemTemplate>
				<DataTemplate x:DataType="vm:BoxViewModel">
					<views:BoxView HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
				</DataTemplate>
			</Carousel.ItemTemplate>
		</Carousel>
	</DockPanel>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SilphScope.ViewModels"
			 xmlns:local="using:SilphScope"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SilphScope.Views.ucBoxedPokemon"
             x:DataType="vm:PokemonViewModel">
    <Design.DataContext>
		<vm:PokemonViewModel/>
	</Design.DataContext>
    <Image Source="{Binding Sprite}" RenderOptions.BitmapInterpolationMode="HighQuality"/>
</UserControl>

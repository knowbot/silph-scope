<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:SilphScope.ViewModels"
			 xmlns:local="using:SilphScope"
			 xmlns:views="using:SilphScope.Views"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="SilphScope.Views.ucBox"
			 x:DataType="vm:BoxViewModel">
	<Design.DataContext>
		<vm:BoxViewModel/>
	</Design.DataContext>

	<ListBox ItemsSource="{Binding Contents}" SelectedItem="{Binding Selected}" ScrollViewer.VerticalScrollBarVisibility="Disabled" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
		<ListBox.ItemsPanel>
			<ItemsPanelTemplate>
				<UniformGrid Rows="5" Columns="6" UseLayoutRounding="False"/>
			</ItemsPanelTemplate>
		</ListBox.ItemsPanel>
		<ListBox.ItemTemplate>
			<DataTemplate x:DataType="vm:PokemonViewModel">
				<views:ucBoxedPokemon/>
			</DataTemplate>
		</ListBox.ItemTemplate>
	</ListBox>
</UserControl>

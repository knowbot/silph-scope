<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:vm="clr-namespace:SilphScope.ViewModels"
			 xmlns:local="using:SilphScope"
			 x:Class="SilphScope.ucMoveSet"
			 x:DataType="vm:MoveSetViewModel"
			 x:Name="root">
	<StackPanel Orientation="Vertical">
		<!-- Header -->
		<TextBlock Text="Moves" FontWeight="Bold"/>

		<!-- Separator -->
		<Border Height="{StaticResource BaseSpacing}" HorizontalAlignment="Stretch">
			<Rectangle Height="1" HorizontalAlignment="Stretch" VerticalAlignment="Center" Fill="{Binding #root.Foreground}"/>
		</Border>

		<!-- Moves -->
		<ItemsControl ItemsSource="{Binding Moves}" ClipToBounds="False">
			<ItemsControl.ItemsPanel>
				<ItemsPanelTemplate>
					<StackPanel Orientation="Vertical" Spacing="{StaticResource BaseSpacing}"/>
				</ItemsPanelTemplate>
			</ItemsControl.ItemsPanel>
			<ItemsControl.ItemTemplate>
				<DataTemplate x:DataType="vm:MoveViewModel">
					<local:ucMove ClipToBounds="False"/>
				</DataTemplate>
			</ItemsControl.ItemTemplate>
		</ItemsControl>
	</StackPanel>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="clr-namespace:SilphScope.ViewModels"
			 xmlns:local="using:SilphScope"
             x:Class="SilphScope.ucMoveSet"
             x:DataType="vm:MoveSetViewModel">
    <ItemsControl ItemsSource="{Binding Moves}">
		<ItemsControl.ItemTemplate>
			<DataTemplate x:DataType="vm:MoveViewModel">
				<local:ucMove/>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
